# Copy this file to .env locally or configure the same keys in Streamlit/GitHub secrets.
# Do not commit real passwords.

MONGODB_USERNAME=your_username
MONGODB_PASSWORD=your_password
MONGODB_CLUSTER=your_cluster_hostname
# Alternative: provide the complete URI as one secret.
# MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority

MONGODB_DATABASE=karachi_aqi
BACKFILL_START_DATE=2023-01-01
REQUEST_TIMEOUT_SECONDS=30
MODEL_RETENTION_DAYS=7
